WEB_PORT=8000
DOVI_MANAGER_IMAGE=ghcr.io/dovi-manager/dovi-manager:edge
PUID=1000
PGID=1000
TZ=UTC

MEDIA_PATH=/path/on/host/to/movies
TV_MEDIA_PATH=/path/on/host/to/tv
MEDIA_ROOT_LABEL=Movies
ADDITIONAL_MEDIA_ROOTS_JSON=[{"id":"tv","label":"TV Shows","path":"/media2/tv"}]
CACHE_PATH=/path/on/host/to/cache
CONFIG_PATH=/path/on/host/to/dovi-manager-config

SCAN_DEPTH=5
STABILITY_SECONDS=30
RETENTION_DAYS=30
JOB_LOG_LIMIT=1000000
SCAN_OUTPUT_LIMIT_BYTES=20971520
DISK_RESERVE_GIB=2
SHUTDOWN_GRACE_SECONDS=20
STOP_GRACE_PERIOD=45s

AUTH_USERNAME=admin
AUTH_PASSWORD=replace-with-a-long-password

# Set this to the reverse proxy IP/CIDR only when using proxy headers.
FORWARDED_ALLOW_IPS=127.0.0.1
